# --- Chert ---
CHERT_API_BASE=https://console.trychert.com/api/v1
CHERT_SIGNING_SECRET=
# Single-tenant default: leave blank. Set if you flip to multi-tenant.
CHERT_TENANT_SLUG=
# Optional: separate webhook secret returned by /webhook-subscriptions.
# If unset, falls back to CHERT_SIGNING_SECRET.
CHERT_WEBHOOK_SECRET=

# --- Google (OAuth user credentials) ---
# Local dev (default): reads JSON from these file paths.
GOOGLE_OAUTH_CLIENT_PATH=.secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_PATH=.secrets/google-oauth-token.json
# Production (Vercel): paste the JSON contents into these env vars instead;
# they take precedence over the file paths.
# GOOGLE_OAUTH_CLIENT_JSON=
# GOOGLE_OAUTH_TOKEN_JSON=
GOOGLE_SHEETS_ID=
SHARE_WITH_EMAIL=gary@trychert.com

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- App ---
ADMIN_SECRET=
CRON_SECRET=
APP_URL=
